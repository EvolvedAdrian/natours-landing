{
  "name": "my-guess-number",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "watch": "sass -w sass/main.scss css/style.css",
    "devserver": "live-server",
    "start": "npm-run-all --parallel devserver watch",
    "compile": "sass --no-source-map sass/main.scss css/style.css",
    "minimize": "postcss -o css/style.min.css css/style.css",
    "build": "npm-run-all compile minimize"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.4",
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^11.0.1",
    "sass": "^1.88.0"
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {},
      "cssnano": {
        "preset": "default"
      }
    },
    "options": {
      "map": false
    }
  }
}